{
	"name": "roviolt-academy",
	"private": true,
	"version": "0.0.3",
	"type": "module",
	"scripts": {
		"dev": "vite dev",
		"build": "vite build",
		"preview": "vite preview",
		"prepare": "svelte-kit sync || echo ''",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"format": "biome format --write",
		"lint": "biome check --write && eslint .",
		"test:unit": "vitest",
		"test:server": "pnpm exec vitest run --project server",
		"test": "npm run test:unit -- --run && npm run test:e2e",
		"test:e2e": "playwright install && playwright test",
		"db:push": "drizzle-kit push",
		"db:generate": "drizzle-kit generate",
		"db:migrate": "drizzle-kit migrate",
		"db:studio": "drizzle-kit studio",
		"auth:schema": "better-auth generate --config src/lib/server/auth.ts --output src/lib/server/db/auth.schema.ts --yes"
	},
	"devDependencies": {
		"@better-auth/cli": "~1.4.21",
		"@biomejs/biome": "^2.4.15",
		"@dnd-kit-svelte/svelte": "^0.1.6",
		"@dnd-kit/abstract": "^0.4.0",
		"@dnd-kit/helpers": "^0.4.0",
		"@eslint/compat": "^2.1.0",
		"@eslint/js": "^10.0.1",
		"@fontsource-variable/geist": "^5.2.9",
		"@fontsource-variable/inter": "^5.2.8",
		"@fontsource-variable/jetbrains-mono": "^5.2.8",
		"@internationalized/date": "^3.12.1",
		"@neondatabase/serverless": "^1.1.0",
		"@playwright/test": "^1.60.0",
		"@sveltejs/adapter-auto": "^7.0.1",
		"@sveltejs/kit": "^2.61.1",
		"@sveltejs/vite-plugin-svelte": "^7.1.2",
		"@tabler/icons-svelte": "^3.44.0",
		"@tailwindcss/forms": "^0.5.11",
		"@tailwindcss/typography": "^0.5.19",
		"@tailwindcss/vite": "^4.3.0",
		"@tanstack/table-core": "^8.21.3",
		"@types/d3-scale": "^4.0.9",
		"@types/d3-shape": "^3.1.8",
		"@types/node": "^24.12.4",
		"@vitest/browser-playwright": "^4.1.7",
		"better-auth": "~1.4.22",
		"bits-ui": "^2.18.1",
		"clsx": "^2.1.1",
		"d3-scale": "^4.0.2",
		"d3-shape": "^3.2.0",
		"dotenv": "^17.4.2",
		"drizzle-kit": "^0.31.10",
		"drizzle-orm": "^0.45.2",
		"eslint": "^10.4.0",
		"eslint-plugin-svelte": "^3.17.1",
		"globals": "^17.6.0",
		"layerchart": "2.0.0-next.48",
		"mdsvex": "^0.12.7",
		"phosphor-svelte": "^3.1.0",
		"playwright": "^1.60.0",
		"shadcn-svelte": "^1.2.7",
		"svelte": "^5.55.9",
		"svelte-check": "^4.4.8",
		"svelte-sonner": "^1.1.1",
		"tailwind-merge": "^3.6.0",
		"tailwind-variants": "^3.2.2",
		"tailwindcss": "^4.3.0",
		"tw-animate-css": "^1.4.0",
		"typescript": "^6.0.3",
		"typescript-eslint": "^8.60.0",
		"vaul-svelte": "1.0.0-next.7",
		"vite": "^8.0.14",
		"vitest": "^4.1.7",
		"vitest-browser-svelte": "^2.1.1",
		"zod": "^4.4.3"
	},
	"dependencies": {
		"@aws-sdk/client-s3": "^3.1053.0",
		"@aws-sdk/s3-request-presigner": "^3.1053.0",
		"@node-rs/argon2": "^2.0.2",
		"@sentry/sveltekit": "^10.53.1",
		"inngest": "^4.4.0",
		"mode-watcher": "^1.1.0",
		"resend": "^6.12.4"
	}
}
